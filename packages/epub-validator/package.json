{
  "name": "@swibostyle/epub-validator",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "EPUB validation using W3C EPubCheck with automatic fallback",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin/epubcheck.jar",
    "bin/lib"
  ],
  "scripts": {
    "build": "tsc && bun scripts/postbuild.ts",
    "dev": "tsc --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "optionalDependencies": {
    "@swibostyle/epub-validator-linux-x64": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "bun-types": "^1.3.6",
    "typescript": "^5.9.3"
  }
}
