{
  "name": "@swibostyle/epub-validator",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "EPUB validation using EPubCheck compiled to WebAssembly",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build:wasm": "cd java && mvn clean process-classes -B",
    "build:ts": "tsc",
    "build": "bun run build:wasm && bun run build:ts",
    "dev": "tsc --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "validate": "bun scripts/validate.ts"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "bun-types": "^1.3.6",
    "typescript": "^5.9.3"
  }
}
