{
  "name": "@swibostyle/cli",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "CLI for swibostyle CSS typesetting tool",
  "repository": {
    "type": "git",
    "url": "https://github.com/swibostyle/swibostyle-cli.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": {
    "swibostyle": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./init": {
      "types": "./dist/init/index.d.ts",
      "import": "./dist/init/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@hono/node-server": "^1.19.9",
    "@swibostyle/core": "workspace:*",
    "commander": "^14.0.2",
    "fflate": "^0.8.2",
    "ora": "^9.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@swibostyle/pdf-renderer": "workspace:*",
    "@swibostyle/pdf-server": "workspace:*",
    "@types/node": "^25.0.10",
    "bun-types": "^1.3.6",
    "typescript": "^5.9.3"
  }
}
