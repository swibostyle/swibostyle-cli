{
  "name": "@swibostyle/pdf-renderer",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "PDF renderer for swibostyle using Playwright",
  "repository": {
    "type": "git",
    "url": "https://github.com/swibostyle/swibostyle-cli.git",
    "directory": "packages/pdf-renderer"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": {
    "swibostyle-pdf-renderer": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "playwright": "^1.56.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "bun-types": "^1.3.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
