{
  "name": "@swibostyle/epub-validator-linux-x64",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "EPubCheck with bundled JRE for Linux x64 (no Java required)",
  "repository": {
    "type": "git",
    "url": "https://github.com/swibostyle/swibostyle-cli.git",
    "directory": "packages/epub-validator-linux-x64"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "os": ["linux"],
  "cpu": ["x64"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "jre",
    "epubcheck.jar",
    "lib"
  ],
  "scripts": {
    "build": "tsup",
    "build:jre": "./scripts/build-jre.sh",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "typescript": "^5.9.3"
  }
}
