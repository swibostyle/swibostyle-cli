{
  "name": "swibostyle-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "CSS typesetting CLI tool for EPUB generation",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter '*' dev",
    "test": "bun test",
    "test:unit": "bun test packages/*/src",
    "test:integration": "bun test tests/integration",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint --tsconfig tsconfig.base.json --ignore-pattern 'tests/fixtures/**' .",
    "lint:fix": "oxlint --tsconfig tsconfig.base.json --ignore-pattern 'tests/fixtures/**' --fix .",
    "format": "oxfmt --ignore-path .oxfmtignore --write packages tests/integration",
    "format:check": "oxfmt --ignore-path .oxfmtignore --check packages tests/integration",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "bun-types": "^1.3.6",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "typescript": "^5.9.3"
  }
}
